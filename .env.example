# =============================================
# CINE AI — Environment Variables
# =============================================
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to version control (it is gitignored).

# --- REQUIRED: chat brain (free, fast, reliable) ---
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# --- OPTIONAL but recommended: movie posters/data (free) ---
# Get from: https://www.themoviedb.org/settings/api
NEXT_PUBLIC_TMDB_API_KEY=

# Get from: https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# --- OPTIONAL: alternate chat backend ---
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- APP CONFIG ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
